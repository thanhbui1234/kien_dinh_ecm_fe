{
  "name": "shared-api",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "gen-api": "swagger-typescript-api generate --path https://kien-dinh-ecm-be.onrender.com/api/docs-json --output ./src/docs --name dto-api.ts --no-client --no-response-common",
    "download-spec": "node -e \"const fs = require('fs'); fs.mkdirSync('./src/docs', { recursive: true });\" && curl -s https://kien-dinh-ecm-be.onrender.com/api/docs-json -o ./src/docs/swagger-spec.json"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "swagger-typescript-api": "^13.12.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
